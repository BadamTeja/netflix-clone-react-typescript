pipeline {
    agent any

    tools {
        nodejs 'nodejs'   // make sure this exists in Jenkins
    }

    environment {
        DOCKER_IMAGE = "netflix-clone:${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout Code') {
            steps {
               checkout scmGit(branches: [[name: '*/main']], extensions: [], userRemoteConfigs: [[credentialsId: 'git-creds', url: 'https://github.com/BadamTeja/netflix-clone-react-typescript.git']])
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install -g yarn'
                sh 'yarn install'
            }
        }

        stage('Build') {
            steps {
                sh 'yarn build'
            }
        }

        stage('Test') {
            steps {
                echo 'No tests available'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'sonar-scanner'
                    withSonarQubeEnv('sonar-server') {
                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=netflix-clone \
                        -Dsonar.sources=src
                        """
                    }
                }
            }
        }

        stage('Verify Build Output') {
            steps {
                sh 'ls -la dist'
            }
        }

stage('Upload to Nexus') {
    steps {
        withCredentials([usernamePassword(
            credentialsId: 'nexus-creds',
            usernameVariable: 'NEXUS_USER',
            passwordVariable: 'NEXUS_PASS'
        )]) {
            sh '''
            echo "Zipping build..."
            zip -r dist/app.zip dist

            echo "Uploading to Nexus..."
            curl -v -u $NEXUS_USER:$NEXUS_PASS \
            --upload-file dist/app.zip \
            http://3.6.87.154:8081/repository/raw-hosted/app.zip
            '''
        }
    }
}
        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $DOCKER_IMAGE .'
            }
        }

    }

    post {
        success {
            echo '✅ Pipeline Successful'
        }
        failure {
            echo '❌ Pipeline Failed'
        }
    }
}
